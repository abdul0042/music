{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/assets/(.*)", "destination": "/frontend/assets/$1" },
    { "source": "/(favicon.ico|manifest.json|icon-192.png|sw.js)", "destination": "/frontend/$1" },
    { "source": "/((?!api).*)", "destination": "/frontend/index.html" }
  ],
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ]
}